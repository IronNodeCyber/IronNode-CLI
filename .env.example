# IronNode CLI Configuration
# Copy this file to .env and customize as needed

# Custom TON Network RPC URL (optional)
# If not set, IronNode will use public RPC endpoints:
#   - https://toncenter.com/api/v2/jsonRPC (primary)
#   - https://ton.access.orbs.network (fallback)
#   - https://ton-mainnet.core.chainstack.com (fallback)
#
# TON_RPC_URL=https://toncenter.com/api/v2/jsonRPC
